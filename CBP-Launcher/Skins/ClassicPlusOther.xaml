<UserControl x:Class="CBPLauncher.Skins.ClassicPlusOther"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CBPLauncher.Skins"
             mc:Ignorable="d" 
             d:DesignHeight="615" d:DesignWidth="454"
             DataContext="{StaticResource MC}">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Border.Background>
                <!--<LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.50016">-->
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#D4383838" Offset="0"/>
                    <GradientStop Color="#D0222222" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Grid.Column="1" Background="#D0222222" Margin="0,0,0,0">
            <StackPanel Orientation="Vertical" Margin="0,10,10,10" HorizontalAlignment="Center">
                <Button Content="Steam Workshop: CBP Pre-releases" Command="{Binding WorkshopPRCommand}" Width="240" Height="32" FontSize="14" Margin="0,40,0,40"/>

                <StackPanel Orientation="Horizontal" Margin="10,24,10,10" HorizontalAlignment="Right">
                    <TextBlock Text="Alpha 9d (a9d)" Foreground="WhiteSmoke" FontSize="16" Margin="0,3,10,0"/>
                    <Button Width="80" Height="30" Content="Install" Command="{Binding InstallA9dCommand}" FontSize="15" Margin="0,0,7,0"/>
                    <Button Width="80" Height="30" Content="Load" Command="{Binding LoadA9dCommand}" FontSize="15"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,24,10,10" HorizontalAlignment="Right">
                    <TextBlock Text="Pre-Release 1 (PR1)" Foreground="WhiteSmoke" FontSize="16" Margin="0,3,10,0"/>
                    <Button Width="80" Height="30" Content="Install" Command="{Binding InstallPR1Command}" FontSize="15" Margin="0,0,7,0"/>
                    <Button Width="80" Height="30" Content="Load" Command="{Binding LoadPR1Command}" FontSize="15"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,24,10,10" HorizontalAlignment="Right">
                    <TextBlock Text="Pre-Release 2 (PR2)" Foreground="WhiteSmoke" FontSize="16" Margin="0,3,10,0"/>
                    <Button Width="80" Height="30" Content="Install" Command="{Binding InstallPR2Command}" FontSize="15" Margin="0,0,7,0"/>
                    <Button Width="80" Height="30" Content="Load" Command="{Binding LoadPR2Command}" FontSize="15"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,24,10,10" HorizontalAlignment="Right">
                    <TextBlock Text="Pre-Release 3 (PR3)" Foreground="WhiteSmoke" FontSize="16" Margin="0,3,10,0"/>
                    <Button Width="80" Height="30" Content="Install" Command="{Binding InstallPR3Command}" FontSize="15" Margin="0,0,7,0"/>
                    <Button Width="80" Height="30" Content="Load" Command="{Binding LoadPR3Command}" FontSize="15"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>